# Frontend (Supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google AdSense
# Activar anuncios en producción cambiando a 'true'
VITE_ADS_ENABLED=false
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_SLOT_HOME_BANNER=
VITE_ADSENSE_SLOT_GAME_SIDEBAR=
VITE_ADSENSE_SLOT_RESULTS_RECT=

# ─────────────────────────────────────────────────────────────────────────────
# Las credenciales de Spotify NO van aquí.
# Se configuran exclusivamente en las Edge Functions de Supabase mediante:
#
#   supabase secrets set SPOTIFY_CLIENT_ID=your-client-id
#   supabase secrets set SPOTIFY_CLIENT_SECRET=your-client-secret
#
# Ver: supabase/SECRETS_SETUP.md
# ─────────────────────────────────────────────────────────────────────────────
